# IMPORTANT: allow package files
!package.json
!package-lock.json

# Node
node_modules/
dist/
.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python scripts (your generators)
__pycache__/
*.pyc

# Temp / data files
*.tsv
*.txt

# Large datasets (optional — keeps repo light)
lichess_db_puzzle.csv

# Local folders you don’t want in repo (optional)
pgn_import/
pgn_import_one/
pgn_rebuild/
stockfish-windows-x86-64-avx2/

# KEEP your app code and public assets
!src/
!public/